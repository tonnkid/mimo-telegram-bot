# MiMo Telegram Bot — Environment Variables
# Copy to .env and fill in your keys

# Telegram Bot Token (required)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# MiMo API (primary — get from 100t.xiaomimimo.com)
MIMO_API_KEY_1=your_mimo_key_1_here
MIMO_API_KEY_2=your_mimo_key_2_here

# OpenRouter (fallback 1 — free models available)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# DeepSeek (fallback 2 — cheap & good for coding)
# Get key: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Groq (fallback 3 — ultra fast, free tier)
# Get key: https://console.groq.com
GROQ_API_KEY=
